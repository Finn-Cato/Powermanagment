  "flow": {
    "triggers": [
      {
        "id": "power_limit_exceeded",
        "title": {
          "en": "Power limit exceeded",
          "no": "Effektgrense overskredet"
        },
        "tokens": [
          {
            "name": "power",
            "type": "number",
            "title": {
              "en": "Power (W)",
              "no": "Effekt (W)"
            },
            "example": 5200
          }
        ]
      },
      {
        "id": "mitigation_applied",
        "title": {
          "en": "Mitigation applied to a device",
          "no": "Tiltak iverksatt på en enhet"
        },
        "tokens": [
          {
            "name": "device_name",
            "type": "string",
            "title": {
              "en": "Device name",
              "no": "Enhetsnavn"
            },
            "example": "Floor heater"
          },
          {
            "name": "action",
            "type": "string",
            "title": {
              "en": "Action",
              "no": "Handling"
            },
            "example": "onoff"
          }
        ]
      },
      {
        "id": "mitigation_cleared",
        "title": {
          "en": "Mitigation cleared",
          "no": "Tiltak opphevet"
        },
        "tokens": [
          {
            "name": "device_name",
            "type": "string",
            "title": {
              "en": "Device name",
              "no": "Enhetsnavn"
            },
            "example": "Floor heater"
          }
        ]
      },
      {
        "id": "profile_changed",
        "title": {
          "en": "Active profile changed",
          "no": "Aktiv profil endret"
        },
        "tokens": [
          {
            "name": "profile",
            "type": "string",
            "title": {
              "en": "Profile",
              "no": "Profil"
            },
            "example": "strict"
          }
        ]
      },
      {
        "id": "mode_changed",
        "title": {
          "en": "Mode changed",
          "no": "Modus endret"
        },
        "tokens": [
          {
            "name": "mode",
            "type": "string",
            "title": {
              "en": "Mode",
              "no": "Modus"
            },
            "example": "night"
          }
        ]
      },
      {
        "id": "charger_should_change_current",
        "title": {
          "en": "Charger current should change",
          "no": "Ladestrøm bør endres"
        },
        "tokens": [
          {
            "name": "device_name",
            "type": "string",
            "title": {
              "en": "Charger name",
              "no": "Ladernavn"
            },
            "example": "My EV Charger"
          },
          {
            "name": "current_a",
            "type": "number",
            "title": {
              "en": "Current (A)",
              "no": "Ladestrøm (A)"
            },
            "example": 10
          }
        ]
      },
      {
        "id": "charger_should_pause",
        "title": {
          "en": "Charger should pause",
          "no": "Ladingen bør stoppes"
        },
        "tokens": [
          {
            "name": "device_name",
            "type": "string",
            "title": {
              "en": "Charger name",
              "no": "Ladernavn"
            },
            "example": "My EV Charger"
          }
        ]
      },
      {
        "id": "charger_should_resume",
        "title": {
          "en": "Charger should resume",
          "no": "Ladingen bør startes"
        },
        "tokens": [
          {
            "name": "device_name",
            "type": "string",
            "title": {
              "en": "Charger name",
              "no": "Ladernavn"
            },
            "example": "My EV Charger"
          },
          {
            "name": "current_a",
            "type": "number",
            "title": {
              "en": "Starting current (A)",
              "no": "Startstrøm (A)"
            },
            "example": 6
          }
        ]
      },
      {
        "id": "all_devices_exhausted",
        "title": {
          "en": "All devices exhausted — still over limit",
          "no": "Alle enheter uttømt — fortsatt over grensen"
        },
        "tokens": [
          {
            "name": "power",
            "type": "number",
            "title": {
              "en": "Current power (W)",
              "no": "Nåværende forbruk (W)"
            },
            "example": 8500
          },
          {
            "name": "limit",
            "type": "number",
            "title": {
              "en": "Power limit (W)",
              "no": "Effektgrense (W)"
            },
            "example": 7000
          },
          {
            "name": "over",
            "type": "number",
            "title": {
              "en": "Over limit by (W)",
              "no": "Over grensen med (W)"
            },
            "example": 1500
          }
        ]
      }
    ],
    "conditions": [
      {
        "id": "guard_enabled",
        "title": {
          "en": "Power Guard is enabled",
          "no": "Power Guard er aktivert"
        }
      },
      {
        "id": "is_over_limit",
        "title": {
          "en": "Power is over limit",
          "no": "Effekten er over grensen"
        }
      },
      {
        "id": "profile_is",
        "title": {
          "en": "Active profile is",
          "no": "Aktiv profil er"
        },
        "titleFormatted": {
          "en": "Active profile is [[profile]]",
          "no": "Aktiv profil er [[profile]]"
        },
        "args": [
          {
            "name": "profile",
            "type": "dropdown",
            "title": {
              "en": "Profile",
              "no": "Profil"
            },
            "values": [
              {
                "id": "normal",
                "label": {
                  "en": "Normal",
                  "no": "Normal"
                }
              },
              {
                "id": "strict",
                "label": {
                  "en": "Strict (90% limit)",
                  "no": "Streng (90% grense)"
                }
              },
              {
                "id": "solar",
                "label": {
                  "en": "Solar-friendly",
                  "no": "Sol-vennlig"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "mode_is",
        "title": {
          "en": "Active mode is",
          "no": "Aktivt modus er"
        },
        "titleFormatted": {
          "en": "Active mode is [[mode]]",
          "no": "Aktivt modus er [[mode]]"
        },
        "args": [
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "no": "Modus"
            },
            "values": [
              {
                "id": "home",
                "label": {
                  "en": "Home",
                  "no": "Hjemme"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "no": "Natt"
                }
              },
              {
                "id": "away",
                "label": {
                  "en": "Away",
                  "no": "Borte"
                }
              },
              {
                "id": "holiday",
                "label": {
                  "en": "Holiday",
                  "no": "Ferie"
                }
              }
            ]
          }
        ]
      }
    ],
    "actions": [
      {
        "id": "enable_guard",
        "title": {
          "en": "Enable Power Guard",
          "no": "Aktiver Power Guard"
        }
      },
      {
        "id": "disable_guard",
        "title": {
          "en": "Disable Power Guard",
          "no": "Deaktiver Power Guard"
        }
      },
      {
        "id": "set_profile",
        "title": {
          "en": "Set active profile",
          "no": "Sett aktiv profil"
        },
        "titleFormatted": {
          "en": "Set active profile to [[profile]]",
          "no": "Sett aktiv profil til [[profile]]"
        },
        "args": [
          {
            "name": "profile",
            "type": "dropdown",
            "title": {
              "en": "Profile",
              "no": "Profil"
            },
            "values": [
              {
                "id": "normal",
                "label": {
                  "en": "Normal",
                  "no": "Normal"
                }
              },
              {
                "id": "strict",
                "label": {
                  "en": "Strict (90% limit)",
                  "no": "Streng (90% grense)"
                }
              },
              {
                "id": "solar",
                "label": {
                  "en": "Solar-friendly",
                  "no": "Sol-vennlig"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "set_mode",
        "title": {
          "en": "Set mode",
          "no": "Sett modus"
        },
        "titleFormatted": {
          "en": "Set mode to [[mode]]",
          "no": "Sett modus til [[mode]]"
        },
        "args": [
          {
            "name": "mode",
            "type": "dropdown",
            "title": {
              "en": "Mode",
              "no": "Modus"
            },
            "values": [
              {
                "id": "home",
                "label": {
                  "en": "Home",
                  "no": "Hjemme"
                }
              },
              {
                "id": "night",
                "label": {
                  "en": "Night",
                  "no": "Natt"
                }
              },
              {
                "id": "away",
                "label": {
                  "en": "Away",
                  "no": "Borte"
                }
              },
              {
                "id": "holiday",
                "label": {
                  "en": "Holiday",
                  "no": "Ferie"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "reset_statistics",
        "title": {
          "en": "Reset statistics",
          "no": "Tilbakestill statistikk"
        }
      },
      {
        "id": "report_power",
        "title": {
          "en": "Report current power consumption",
          "no": "Rapporter aktuelt strømforbruk"
        },
        "titleFormatted": {
          "en": "Report current power consumption as [[power_w]] W",
          "no": "Rapporter aktuelt strømforbruk som [[power_w]] W"
        },
        "args": [
          {
            "name": "power_w",
            "type": "number",
            "title": {
              "en": "Power (W)",
              "no": "Effekt (W)"
            },
            "min": 0,
            "max": 100000,
            "step": 1,
            "placeholder": {
              "en": "e.g. 3500",
              "no": "f.eks. 3500"
            }
          }
        ]
      },
      {
        "id": "suspend_han_monitoring",
        "title": {
          "en": "Suspend HAN missing-data protection",
          "no": "Suspender HAN manglende-data-beskyttelse"
        },
        "titleFormatted": {
          "en": "Suspend HAN missing-data protection for [[duration_minutes]] minutes",
          "no": "Suspender HAN manglende-data-beskyttelse i [[duration_minutes]] minutter"
        },
        "args": [
          {
            "name": "duration_minutes",
            "type": "number",
            "title": {
              "en": "Duration (minutes)",
              "no": "Varighet (minutter)"
            },
            "min": 1,
            "max": 60,
            "step": 1,
            "placeholder": {
              "en": "e.g. 10",
              "no": "f.eks. 10"
            }
          }
        ]
      },
      {
        "id": "report_ev_power",
        "title": {
          "en": "Report EV charger power consumption",
          "no": "Rapporter effektforbruk for elbillader"
        },
        "titleFormatted": {
          "en": "Report [[charger]]: [[power]] W",
          "no": "Rapporter [[charger]]: [[power]] W"
        },
        "args": [
          {
            "name": "charger",
            "type": "autocomplete",
            "title": {
              "en": "Charger",
              "no": "Lader"
            },
            "placeholder": {
              "en": "Select charger…",
              "no": "Velg lader…"
            }
          },
          {
            "name": "power",
            "type": "number",
            "title": {
              "en": "Power (W)",
              "no": "Effekt (W)"
            },
            "min": 0,
            "max": 50000,
            "step": 1,
            "placeholder": {
              "en": "e.g. 6900",
              "no": "f.eks. 6900"
            }
          }
        ]
      },
      {
        "id": "report_ev_car_connected",
        "title": {
          "en": "Report EV car connected/disconnected",
          "no": "Rapporter elbil tilkoblet/frakoblet"
        },
        "titleFormatted": {
          "en": "Report [[charger]]: car [[connected]]",
          "no": "Rapporter [[charger]]: bil [[connected]]"
        },
        "args": [
          {
            "name": "charger",
            "type": "autocomplete",
            "title": {
              "en": "Charger",
              "no": "Lader"
            },
            "placeholder": {
              "en": "Select charger…",
              "no": "Velg lader…"
            }
          },
          {
            "name": "connected",
            "type": "dropdown",
            "title": {
              "en": "Status",
              "no": "Status"
            },
            "values": [
              {
                "id": "true",
                "label": {
                  "en": "Connected",
                  "no": "Tilkoblet"
                }
              },
              {
                "id": "false",
                "label": {
                  "en": "Disconnected",
                  "no": "Frakoblet"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "report_ev_battery",
